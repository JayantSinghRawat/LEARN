<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All users</title>
</head>
<body>
    <h1>All user data</h1>
    <a href = "/users/new">add new entry</a>
    <table border="1">
         <tr> 
            <th>id</th>
            <th>username</th>
            <th>email</th>
            <th>Edit Username</th>
            <th>Delete User</th>
         </tr>
         <% for(let i = 0; i< result.length; i++) {%>
            <tr>
                <td> <%= result[i].id %></td>
                <td> <%= result[i].username %></td>
                <td> <%= result[i].email %></td>
                <td><form action = "/users/<%=result[i].id%>" method = "get"><button>edit username</button></form></td>
                <td><form action = "/users/<%=result[i].id%>?_method=DELETE" method = "post"><button>Delete</button></form></td>
            </tr>
        <%}%>
    </table>
</body>
</html>